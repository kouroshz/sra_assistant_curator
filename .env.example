# Optional API configuration.
# Copy this file to .env and fill in your own key if you want to run API-assisted curation.
# The deterministic pipeline does not require this.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_SMALL_MODEL=gpt-5.4-mini

# API curation is disabled by default.
# Set to 1 only when intentionally running API-assisted scripts.
AGENTIC_AI_ENABLE_API=0

# Optional NCBI configuration for deterministic public metadata fetching.
# NCBI_EMAIL is recommended for larger jobs.
# NCBI_API_KEY is optional.
NCBI_EMAIL=
NCBI_API_KEY=
NCBI_TOOL=sra_paper_curator
